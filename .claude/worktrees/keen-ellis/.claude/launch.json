{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Node Static Server",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url==='/'?'/index.html':q.url,f=p.join(process.cwd(),u),e=p.extname(f),t={'.html':'text/html','.css':'text/css','.js':'application/javascript','.png':'image/png','.jpg':'image/jpeg','.svg':'image/svg+xml'};fs.readFile(f,(err,d)=>{if(err){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':t[e]||'application/octet-stream'});r.end(d)}})}).listen(3000,()=>console.log('Server running on port 3000'))"],
      "port": 3000
    }
  ]
}
